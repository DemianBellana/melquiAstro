---
const leftText = 'Video Editor &';
const rightText = 'Content Creator';

const renderLetters = (text: string, className: string) =>
  text.split('').map((char) => ({
    char,
    className
  }));

const leftLetters = renderLetters(leftText, 'char-left');
const rightLetters = renderLetters(rightText, 'char-right');
---

<section
  id="inicio"
  class="min-h-[70vh] lg:min-h-screen h-auto relative flex flex-col lg:justify-center items-center justify-start overflow-hidden bg-[#707f6a] lg:bg-transparent pt-[74px] lg:pt-0"
>
  <video
    autoPlay
    loop
    muted
    playsInline
    poster="/herovideo2_poster.jpg"
    class="relative lg:absolute lg:inset-0 w-full aspect-video lg:aspect-auto lg:h-full object-cover z-0"
  >
    <source src="/herovideo2.mp4?v=3" type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-black/20 z-10 hidden lg:block"></div>

  <div class="relative z-20 text-center text-white px-6 py-8 lg:py-0 perspective-1000 w-full max-w-[800px] flex flex-col items-center justify-center flex-1">
    <h1 class="font-serif text-[clamp(3rem,7vw,6.5rem)] font-light italic leading-[1.08] mb-6 overflow-hidden">
      <div class="flex justify-center flex-wrap">
        {leftLetters.map(({ char, className }) => (
          <span class={`${className} inline-block whitespace-pre`}>{char}</span>
        ))}
      </div>
      <div class="flex justify-center flex-wrap">
        {rightLetters.map(({ char, className }) => (
          <span class={`${className} inline-block whitespace-pre`}>{char}</span>
        ))}
      </div>
    </h1>

    <div class="hero-badge opacity-0 inline-flex items-center gap-2 sm:gap-3 bg-green/40 backdrop-blur-md border border-white/10 rounded-full px-4 py-1.5 sm:px-5 sm:py-1.5 text-white/90 text-[10px] sm:text-[11px] tracking-[0.05em] sm:tracking-[0.22em] uppercase shadow-lg whitespace-nowrap mb-7">
      Dinámica &amp; Creatividad · Historias que impactan
      <span class="w-1 h-1 sm:w-1.5 sm:h-1.5 rounded-full bg-[#7C8F7A] animate-pulse"></span>
    </div>

    <!-- CTA -->
    <div class="flex justify-center">
      <button
        id="hero-cta-btn"
        class="hero-cta opacity-0 group relative overflow-hidden flex items-center gap-3
                   bg-[#ff4d6d] border border-[#ff4d6d] rounded-full
                   px-8 py-3.5
                   font-sans text-[10px] tracking-[0.22em] uppercase text-white
                   transition-all duration-400 ease-out
                   hover:bg-[#e03d5a] hover:border-[#e03d5a]
                   cursor-pointer shadow-lg"
      >
        <!-- fill on hover -->
        <span
          class="absolute inset-0 rounded-full bg-white/5
                     -translate-x-full transition-transform duration-500
                     ease-[cubic-bezier(0.25,0.46,0.45,0.94)]
                     group-hover:translate-x-0"
        ></span>

        <span id="hero-cta-text" class="relative z-10 inline-block">
          Contactame
        </span>

        <!-- arrow -->
        <span class="relative z-10 flex items-center">
          <span
            class="block h-px bg-white/60 transition-all duration-300 ease-out w-3.5 group-hover:w-5 group-hover:bg-white"
          ></span>
          <span
            class="block w-[5px] h-[5px] border-t border-r border-white/60 rotate-45 -ml-[3px]
                       transition-transform duration-300 group-hover:translate-x-[2px] group-hover:border-white"
          ></span>
        </span>
      </button>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  // Animaciones de entrada iniciales
  gsap.from('.char-left', {
    x: -100,
    rotationY: 90,
    rotationZ: -20,
    opacity: 0,
    duration: 1,
    stagger: 0.03,
    ease: 'power3.out',
    delay: 0.5,
  });

  gsap.from('.char-right', {
    x: 100,
    rotationY: -90,
    rotationZ: 20,
    opacity: 0,
    duration: 1,
    stagger: 0.03,
    ease: 'power3.out',
    delay: 0.5,
  });

  gsap.fromTo('.hero-badge',
    { y: 20, opacity: 0, scale: 0.9 },
    { y: 0, opacity: 1, scale: 1, duration: 1, ease: 'power2.out', delay: 1.2 }
  );

  gsap.fromTo('.hero-cta',
    { y: 20, opacity: 0, scale: 0.95 },
    { y: 0, opacity: 1, scale: 1, duration: 1, ease: 'power2.out', delay: 1.5 }
  );

  // Efecto magnético y acción en el botón CTA
  const ctaBtn = document.getElementById('hero-cta-btn');
  const ctaText = document.getElementById('hero-cta-text');

  if (ctaBtn) {
    ctaBtn.addEventListener('mousemove', (e) => {
      if (!ctaText) return;
      const r = ctaBtn.getBoundingClientRect();
      const x = e.clientX - r.left - r.width / 2;
      const y = e.clientY - r.top - r.height / 2;
      gsap.to(ctaText, { x: x * 0.15, y: y * 0.25, duration: 0.3, ease: 'power2.out' });
    });

    ctaBtn.addEventListener('mouseleave', () => {
      if (!ctaText) return;
      gsap.to(ctaText, { x: 0, y: 0, duration: 0.4, ease: 'power2.out' });
    });

    ctaBtn.addEventListener('click', () => {
      window.open('https://wa.me/5491166898081', '_blank', 'noopener,noreferrer');
    });
  }
</script>
