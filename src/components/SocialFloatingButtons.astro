---
// Iconos inline SVG
---

<!-- Versión Desktop: Siempre visible en md+, oculta en móvil -->
<ul 
  id="social-floating-desktop" 
  class="social-floating-list animate-fade-in-up"
  style="display: none;"
>
  <li style="--i: #E1306C; --j: #bc1888;" data-href="https://www.instagram.com/melquigrafias/">
    <span class="icon">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <rect x="2" y="2" width="20" height="20" rx="5.5"></rect>
        <circle cx="12" cy="12" r="4.5"></circle>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
      </svg>
    </span>
    <span class="title">Instagram</span>
  </li>
  <li style="--i: #000000; --j: #444444;" data-href="https://www.tiktok.com/@meelqui">
    <span class="icon">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.93a8.2 8.2 0 0 0 4.78 1.52V7a4.85 4.85 0 0 1-1.01-.31z"></path>
      </svg>
    </span>
    <span class="title">TikTok</span>
  </li>
</ul>

<!-- Versión Móvil: Visible en móvil, oculta en md+ (Desplegable tras solapa vertical) -->
<div 
  id="social-floating-mobile" 
  class="fixed right-0 top-1/2 -translate-y-1/2 items-center justify-end z-[99] h-[130px] w-[95px] select-none animate-fade-in-up"
  style="display: none;"
>
  <!-- Menú de botones -->
  <div 
    id="social-mobile-menu"
    class="absolute right-[31px] flex flex-col gap-3 transition-all duration-300 translate-x-12 opacity-0 pointer-events-none"
  >
    <a
      href="https://www.instagram.com/melquigrafias/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram"
      class="w-[50px] h-[50px] rounded-full flex items-center justify-center text-white border-2 border-white shadow-[0_10px_25px_rgba(0,0,0,0.2)] transition-transform duration-200 active:scale-95"
      style="background-color: #e4405f;"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <rect x="2" y="2" width="20" height="20" rx="5.5"></rect>
        <circle cx="12" cy="12" r="4.5"></circle>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
      </svg>
    </a>
    <a
      href="https://www.tiktok.com/@meelqui"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="TikTok"
      class="w-[50px] h-[50px] rounded-full flex items-center justify-center text-white border-2 border-white shadow-[0_10px_25px_rgba(0,0,0,0.2)] transition-transform duration-200 active:scale-95"
      style="background-color: #000000;"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.93a8.2 8.2 0 0 0 4.78 1.52V7a4.85 4.85 0 0 1-1.01-.31z"></path>
      </svg>
    </a>
  </div>

  <!-- Solapita Vertical -->
  <button 
    id="social-mobile-toggle"
    class="absolute right-0 flex flex-col items-center justify-center gap-2 py-3.5 px-1.5 border-l border-y border-white/20 rounded-l-xl shadow-lg focus:outline-none active:opacity-90"
    style="background-color: #707f6a; color: #E8E2D8; transition: background-color 0.6s ease-in-out, color 0.6s ease-in-out;"
  >
    <span class="[writing-mode:vertical-lr] rotate-180 text-[8.5px] font-semibold tracking-[0.25em] opacity-95">
      REDES
    </span>
    <svg 
      id="social-mobile-arrow"
      class="w-3 h-3 transition-transform duration-300"
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor" 
      stroke-width="3"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path>
    </svg>
  </button>
</div>

<script>
  // Desktop navigation links click
  const desktopItems = document.querySelectorAll('#social-floating-desktop li');
  desktopItems.forEach(item => {
    item.addEventListener('click', () => {
      const url = item.getAttribute('data-href');
      if (url) {
        window.open(url, '_blank', 'noopener,noreferrer');
      }
    });
  });

  // Visibilidad global basada en scroll
  const desktopContainer = document.getElementById('social-floating-desktop') as HTMLElement | null;
  const mobileContainer = document.getElementById('social-floating-mobile') as HTMLElement | null;

  const handleScroll = () => {
    const threshold = window.innerHeight * 0.4;
    const isVisible = window.scrollY > threshold;
    
    if (isVisible) {
      // En desktop mostramos el flex si la pantalla es md+ (>= 768px)
      if (window.innerWidth >= 768) {
        if (desktopContainer) desktopContainer.style.display = 'flex';
        if (mobileContainer) mobileContainer.style.display = 'none';
      } else {
        if (desktopContainer) desktopContainer.style.display = 'none';
        if (mobileContainer) mobileContainer.style.display = 'flex';
      }
    } else {
      if (desktopContainer) desktopContainer.style.display = 'none';
      if (mobileContainer) mobileContainer.style.display = 'none';
    }
  };

  window.addEventListener('scroll', handleScroll, { passive: true });
  window.addEventListener('resize', handleScroll);
  handleScroll();

  // Mobile drawer logic (Toggle)
  const mobileToggle = document.getElementById('social-mobile-toggle');
  const mobileMenu = document.getElementById('social-mobile-menu');
  const mobileArrow = document.getElementById('social-mobile-arrow');
  let isOpen = false;

  mobileToggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      mobileMenu?.classList.remove('translate-x-12', 'opacity-0', 'pointer-events-none');
      mobileMenu?.classList.add('translate-x-0', 'opacity-100', 'pointer-events-auto');
      mobileArrow?.classList.add('rotate-180');
    } else {
      mobileMenu?.classList.add('translate-x-12', 'opacity-0', 'pointer-events-none');
      mobileMenu?.classList.remove('translate-x-0', 'opacity-100', 'pointer-events-auto');
      mobileArrow?.classList.remove('rotate-180');
    }
  });

  // IntersectionObserver para cambiar el color del botón según el footer
  const footerElement = document.querySelector('footer');
  if (footerElement && mobileToggle) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        const isInFooter = entry.isIntersecting;
        if (isInFooter) {
          mobileToggle.style.backgroundColor = '#d8b7af';
          mobileToggle.style.color = '#1a1714';
        } else {
          mobileToggle.style.backgroundColor = '#707f6a';
          mobileToggle.style.color = '#E8E2D8';
        }
      },
      {
        root: null,
        threshold: 0,
        rootMargin: '0px 0px 0px 0px',
      }
    );

    observer.observe(footerElement);
  }
</script>
